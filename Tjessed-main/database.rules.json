{
  "rules": {
    "Accounts": {
      "$uid": {
        // Only the user can read and write their own profile
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "Matchmaking": {
      // Everyone who is authenticated can see the queue to find opponents
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        // Users can only add/remove themselves from the queue
        // EXCEPT: We must allow another user to write 'Status' and 'MatchId' during matchmaking.
        // This is the "Safety vs Functionality" trade-off for client-side matchmaking.
        ".write": "auth != null"
      }
    },
    "Matches": {
      "$matchId": {
        ".read": "auth != null && (data.child('WhiteID').val() == auth.uid || data.child('BlackID').val() == auth.uid)",
        ".write": "auth != null && (!data.exists() || data.child('WhiteID').val() == auth.uid || data.child('BlackID').val() == auth.uid)"
      }
    }
  }
}
